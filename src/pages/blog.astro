---
import Layout from '../layouts/Layout.astro';
import { posts } from '@wix/blog';
import { wixImageToUrl } from '../lib/wix-image';

let blogPosts = [];
let error = null;

try {
  const response = await posts.queryPosts().limit(10).find();
  blogPosts = response.items || [];
} catch (e) {
  console.error("Failed to fetch blog posts:", e);
  error = e.message;
}

const featuredPost = blogPosts.length > 0 ? blogPosts[0] : null;
const regularPosts = blogPosts.length > 1 ? blogPosts.slice(1) : [];

const formatDate = (dateString) => {
  if (!dateString) return '';
  return new Date(dateString).toLocaleDateString('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric'
  }).toUpperCase();
};

const getImageUrl = (post) => {
  return wixImageToUrl(post?.media?.wixMedia?.image)
      || 'https://images.unsplash.com/photo-1549366021-9f761d450615?auto=format&fit=crop&w=1600&q=80';
};
---

<Layout
  title="Journal"
  description="Stories from the field — behind-the-scenes journals from wildlife photography expeditions across Africa, Asia, and the Arctic."
  url="/blog"
>
  <main class="pt-0">
    {error && (
      <div class="max-w-container-max mx-auto px-margin-mobile py-20 text-error">
        <p>Unable to load journal entries at this time. Please try again later.</p>
      </div>
    )}

    {!error && blogPosts.length === 0 && (
       <div class="max-w-container-max mx-auto px-margin-mobile py-20 text-on-surface-variant">
        <p>No journal entries found. Check back soon for stories from the field.</p>
      </div>
    )}

    <!-- Featured Post Hero -->
    {!error && featuredPost && (
      <section class="relative h-[707px] w-full overflow-hidden flex items-end">
        <img class="absolute inset-0 w-full h-full object-cover" src={getImageUrl(featuredPost)} alt={featuredPost.title} />
        <div class="absolute inset-0 bg-gradient-to-t from-[#131313] via-[#131313]/40 to-transparent"></div>
        <div class="relative z-10 w-full max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop pb-20">
          <div class="max-w-3xl">
            <span class="inline-block px-3 py-1 mb-4 border border-primary text-primary font-label-md text-label-md uppercase tracking-widest">Featured Story</span>
            <h1 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-on-surface mb-6 leading-none uppercase">{featuredPost.title}</h1>
            <div class="flex items-center gap-4 mb-8">
              <span class="font-label-md text-label-md text-on-surface-variant uppercase tracking-widest">{formatDate(featuredPost.firstPublishedDate)}</span>
              <span class="w-8 h-px bg-outline-variant"></span>
              <span class="font-label-md text-label-md text-on-surface-variant uppercase tracking-widest">{featuredPost.minutesToRead} Min Read</span>
            </div>
            <a href={`/blog/${featuredPost.slug}`} class="px-8 py-3 border border-primary text-primary font-label-md text-label-md uppercase tracking-widest hover:bg-primary hover:text-on-primary transition-all duration-300 active:scale-95 no-underline inline-block">Read The Feature</a>
          </div>
        </div>
      </section>
    )}

    <!-- Blog Content Area -->
    {!error && blogPosts.length > 0 && (
      <section class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-20">
        <div class="flex flex-col lg:flex-row gap-20">
          <!-- Main Grid -->
          <div class="flex-1">
            <h2 class="font-headline-md text-headline-md text-on-surface mb-12 border-b border-outline-variant pb-4">Latest Journals</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-y-16 gap-x-12">
              {regularPosts.map((post) => (
                <article class="group">
                  <div class="overflow-hidden mb-6 aspect-[4/3]">
                    <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" src={getImageUrl(post)} alt={post.title} />
                  </div>
                  <span class="font-label-md text-label-md text-primary uppercase tracking-widest mb-2 block">Journal</span>
                  <h3 class="font-headline-md text-headline-md text-on-surface mb-3 group-hover:text-primary transition-colors uppercase">{post.title}</h3>
                  <p class="font-caption text-caption text-on-surface-variant mb-4">{formatDate(post.firstPublishedDate)}</p>
                  <p class="font-body-md text-body-md text-on-surface-variant line-clamp-2 mb-6">{post.excerpt}</p>
                  <a class="font-label-md text-label-md text-primary-container uppercase tracking-widest border-b border-transparent hover:border-primary-container transition-all no-underline" href={`/blog/${post.slug}`}>Read More</a>
                </article>
              ))}
            </div>
          </div>

          <!-- Sidebar -->
          <aside class="w-full lg:w-[350px] space-y-16">
            <!-- Bio Section -->
            <div class="bg-surface-container-low p-8 border border-outline-variant/30">
              <h4 class="font-label-md text-label-md text-primary uppercase tracking-widest mb-6">About the Photographer</h4>
              <div class="mb-6 overflow-hidden aspect-square">
                <img class="w-full h-full object-cover grayscale" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAH_vC7VPEry-xtaTrWqOb53OUWOGnkAUK_Arwq8g0_UJozGaeQIuWK_fcaNHPrQEYmDbCYLJZiONLPqfRDFl46f7YLSa45pGuP6-pCE3gmhgDv1T4lU5rQqX21TNzkr414CyUSyghOMWFaetyvkDeKt1zRmfzdJMAeck4hUUsrwRtEj6-rzXa1HFu47rc4L5GGIJF_6sYtQBW0DlvqVBUkPSw-__gKeVcYBelBz29_P2NlctjSSRAUxj0wNhAsVYEvc4gFYP253gQZ" alt="Elias Thorne" />
              </div>
              <p class="font-body-md text-body-md text-on-surface mb-4">Elias Thorne has spent two decades documenting the world's most elusive creatures in their natural habitats.</p>
              <p class="font-caption text-caption text-on-surface-variant mb-6 italic">"Patience is the only gear that truly matters in the wild."</p>
              <a class="font-label-md text-label-md text-on-surface uppercase tracking-widest underline decoration-primary underline-offset-4 hover:text-primary transition-colors" href="#">Full Profile</a>
            </div>
          </aside>
        </div>
      </section>
    )}
  </main>
</Layout>
